# name: test/sql/settings.test
# description: anofox_tabfm_* settings — defaults, validation, aliases (SQL-API §4)
# group: [anofox_tabfm]

require anofox_tabfm

statement ok
LOAD anofox_tabfm

# --- Defaults -----------------------------------------------------------------

query I
SELECT current_setting('anofox_tabfm_accept_hf_license')
----
false

query I
SELECT current_setting('anofox_tabfm_cache_dir')
----
~/.cache/anofox-tabfm

query I
SELECT current_setting('anofox_tabfm_max_rows')
----
10000

query I
SELECT current_setting('anofox_tabfm_max_features')
----
500

query I
SELECT current_setting('anofox_tabfm_model_manifest')
----
(empty)

query I
SELECT current_setting('anofox_tabfm_trace_level')
----
warn

query I
SELECT current_setting('anofox_tabfm_device')
----
auto

query I
SELECT current_setting('anofox_tabfm_ep_path')
----
(empty)

# threads defaults to a positive machine-dependent value
query I
SELECT current_setting('anofox_tabfm_threads') > 0
----
true

# --- Set + read back ------------------------------------------------------------

statement ok
SET anofox_tabfm_accept_hf_license = true

statement ok
SET anofox_tabfm_cache_dir = '/tmp/tabfm-cache'

statement ok
SET anofox_tabfm_max_rows = 500

statement ok
SET anofox_tabfm_threads = 2

# --- Validation ----------------------------------------------------------------

statement error
SET anofox_tabfm_device = 'tpu'
----
<REGEX>:.*must be one of 'auto', 'cpu', 'cuda', 'rocm'.*

# 'migraphx' is accepted as an alias and normalizes to 'rocm'
statement ok
SET anofox_tabfm_device = 'migraphx'

query I
SELECT current_setting('anofox_tabfm_device')
----
rocm

# 'coreml' is a valid device on every flavor (ResolveDevice errors helpfully at
# use time on flavors that do not carry it — like cuda/rocm)
statement ok
SET anofox_tabfm_device = 'coreml'

query I
SELECT current_setting('anofox_tabfm_device')
----
coreml

statement ok
SET anofox_tabfm_device = 'auto'

statement error
SET anofox_tabfm_trace_level = 'loud'
----
<REGEX>:.*must be one of 'error', 'warn', 'info', 'debug', 'trace'.*

statement error
SET anofox_tabfm_max_rows = -1
----
<REGEX>:.*must be positive.*

statement error
SET anofox_tabfm_threads = 0
----
<REGEX>:.*must be positive.*

# --- performance settings (gpu precision, cpu prepack) -----------------------

query T
SELECT current_setting('anofox_tabfm_gpu_precision')
----
bf16

query T
SELECT current_setting('anofox_tabfm_cpu_prepack')
----
true

statement ok
SET anofox_tabfm_gpu_precision = 'fp16'

statement ok
SET anofox_tabfm_gpu_precision = 'fp32'

statement error
SET anofox_tabfm_gpu_precision = 'int4'
----
<REGEX>:.*must be 'bf16', 'fp16' or 'fp32'.*

statement ok
SET anofox_tabfm_cpu_prepack = false

# precompiled .mxr staging source: empty by default, accepts a directory path
query T
SELECT current_setting('anofox_tabfm_mxr_source')
----
(empty)

statement ok
SET anofox_tabfm_mxr_source = '/srv/tabfm/mxr'

query T
SELECT current_setting('anofox_tabfm_mxr_source')
----
/srv/tabfm/mxr

# --- Function surface exists (full name + alias). Behaviour is covered in the
# --- per-module suites: tabfm_weights/license/lifecycle (WS-D),
# --- tabfm_devices (WS-C), tabfm_classify / tabfm_regress. The end-to-end
# --- forward pass against the CI fixture lives in those suites (not here) so
# --- this settings suite stays engine-free and portable to every CI platform.
