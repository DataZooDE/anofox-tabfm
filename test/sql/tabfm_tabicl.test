# name: test/sql/tabfm_tabicl.test
# description: TabICL v2 (soda-inria, BSD-3) onboarded as a real model. Like
#              TabPFN, its ONNX graph is (x, y)-only, so the engine's y-as-train-
#              prefix inference (no train_size input → y is the training prefix)
#              drives it with no model-specific code. Uses the committed random-
#              init fixture (offline, zero TabICL weight bytes). Real-weight
#              accuracy is exercised out-of-band (examples/tabicl.json +
#              tools/export_tabicl/convert_weights.py: iris 0.943). classify only
#              — TabICL regression is a 999-quantile head (see docs/REAL_MODELS.md).
# group: [anofox_tabfm]

require anofox_tabfm

require notwindows

statement ok
LOAD anofox_tabfm

statement ok
SET anofox_tabfm_model_manifest = 'test/fixtures/tabicl/manifest.json'

query TTT
SELECT model, family, capabilities FROM tabfm_list_models() WHERE model = 'tabicl-fixture'
----
tabicl-fixture	icl-transformer	classify

statement ok
CREATE TABLE t AS SELECT * FROM (VALUES
  (0.5,1.0,0.1,'c0'),(1.5,0.2,0.3,'c1'),(2.5,-1.0,0.5,'c2'),
  (0.2,0.8,0.7,'c0'),(1.1,0.4,0.2,'c1'),(3.0,-0.5,0.9,'c2'),
  (0.9,1.2,0.6,'c0'),(2.1,0.1,0.4,'c1'),
  (1.3,0.3,0.35,NULL),(2.4,-0.2,0.55,NULL))
  v(f1,f2,f3,label);

# a real forward pass through the (x, y)-only TabICL graph via the y-prefix path
query II
SELECT count(*), count(*) FILTER (WHERE yhat NOT IN ('c0','c1','c2'))
FROM tabfm_classify('t', 'label', model := 'tabicl-fixture')
----
10	0

query I
SELECT count(*) FROM tabfm_classify('t', 'label', model := 'tabicl-fixture') WHERE yhat IS NULL
----
0
