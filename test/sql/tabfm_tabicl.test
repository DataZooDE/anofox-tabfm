# name: test/sql/tabfm_tabicl.test
# description: TabICL v2 (soda-inria, BSD-3) onboarded as a real model. Like
#              TabPFN, its ONNX graph is (x, y)-only, so the engine's y-as-train-
#              prefix inference (no train_size input → y is the training prefix)
#              drives it with no model-specific code. Uses the committed random-
#              init fixture (offline, zero TabICL weight bytes). Real-weight
#              accuracy is exercised out-of-band (examples/tabicl.json +
#              tools/export_tabicl/convert_weights.py: iris 0.943 classify,
#              california_housing R2 0.82 regress). The fixture ships BOTH graphs:
#              classification (class logits) and regression, whose graph emits a
#              single point estimate per row (logits[1,T,1] = mean over the
#              999-quantile head + in-graph inverse StandardScaler on RAW targets).
# group: [anofox_tabfm]

require anofox_tabfm

require notwindows

statement ok
LOAD anofox_tabfm

statement ok
CALL tabfm_register_model(
  id := 'tabicl-fixture', base_dir := 'test/fixtures/tabicl',
  classification_graph := 'graph_tabicl_classification.onnx',
  regression_graph := 'graph_tabicl_regression.onnx',
  classification_weights := 'model_classification.safetensors',
  regression_weights := 'model_regression.safetensors',
  tensor_map := 'tensor_map_tabicl_classification.json',
  license := 'bsd-3-clause', commercial := true,
  weights_repo := 'local:test/fixtures/tabicl', weights_revision := 'fixture-v1',
  preprocessing_profile := 'tabicl_v2_raw',
  max_rows := 4096, max_features := 64, max_classes := 3)

query TTT
SELECT model, family, capabilities FROM tabfm_list_models() WHERE model = 'tabicl-fixture'
----
tabicl-fixture	icl-transformer	classify, regress

statement ok
CREATE TABLE t AS SELECT * FROM (VALUES
  (0.5,1.0,0.1,'c0'),(1.5,0.2,0.3,'c1'),(2.5,-1.0,0.5,'c2'),
  (0.2,0.8,0.7,'c0'),(1.1,0.4,0.2,'c1'),(3.0,-0.5,0.9,'c2'),
  (0.9,1.2,0.6,'c0'),(2.1,0.1,0.4,'c1'),
  (1.3,0.3,0.35,NULL),(2.4,-0.2,0.55,NULL))
  v(f1,f2,f3,label);

# a real forward pass through the (x, y)-only TabICL graph via the y-prefix path
query II
SELECT count(*), count(*) FILTER (WHERE yhat NOT IN ('c0','c1','c2'))
FROM tabfm_classify('t', 'label', model := 'tabicl-fixture')
----
10	0

query I
SELECT count(*) FROM tabfm_classify('t', 'label', model := 'tabicl-fixture') WHERE yhat IS NULL
----
0

# regression capability runs too — the fixture ships the [1,T,1] point-estimate
# graph. A real forward pass returns a numeric yhat for every test row.
statement ok
CREATE TABLE r AS SELECT * FROM (VALUES
  (0.5,1.0,0.1,1.2),(1.5,0.2,0.3,2.4),(2.5,-1.0,0.5,3.1),
  (0.2,0.8,0.7,0.9),(1.1,0.4,0.2,1.8),(3.0,-0.5,0.9,3.6),
  (0.9,1.2,0.6,1.1),(2.1,0.1,0.4,2.7),
  (1.3,0.3,0.35,NULL),(2.4,-0.2,0.55,NULL))
  v(f1,f2,f3,target);

query II
SELECT count(*), count(*) FILTER (WHERE yhat IS NULL)
FROM tabfm_regress('r', 'target', model := 'tabicl-fixture')
----
10	0
