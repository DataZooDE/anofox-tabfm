# name: test/sql/tabfm_regress.test
# description: tabfm_regress end-to-end through the real engine against the
#              committed regression CI fixture (weight-free graph, random-init
#              safetensors, output [1,T,1]). Predictions are meaningless (random
#              weights) but the full numeric pipeline runs: preprocess ->
#              injection -> ORT forward -> inverse-transform decode.
# group: [anofox_tabfm]

require anofox_tabfm

statement ok
LOAD anofox_tabfm

statement ok
SET anofox_tabfm_model_manifest = 'test/fixtures/regression/manifest.json'

statement ok
CREATE TABLE houses AS SELECT * FROM (VALUES
  (1200,3,200000.0),(2500,5,400000.0),(1500,3,300000.0),(2000,4,350000.0),
  (1800,4,280000.0),(2200,5,420000.0),(1400,3,260000.0),(2800,6,520000.0),
  (1600,4,NULL),(2400,5,NULL),(1300,3,NULL),(2600,5,NULL))
  v(sqft,beds,price);

# --- Single-table: 4 NULL-price rows scored, all rows returned ---------------

query I
SELECT count(*) FROM tabfm_regress('houses','price')
----
12

# every yhat is a finite number; regression has no score and no proba
query I
SELECT count(*) FROM tabfm_regress('houses','price')
WHERE yhat IS NULL OR NOT isfinite(yhat) OR yhat_score IS NOT NULL
----
0

# no proba column for regression
query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM tabfm_regress('houses','price')) WHERE column_name = 'proba'
----
0

# scored rows flagged is_training = false
query I
SELECT count(*) FROM tabfm_regress('houses','price') WHERE price IS NULL AND is_training
----
0

# determinism: two calls agree on every prediction
query I
SELECT count(*) FROM (
  SELECT a.yhat AS y1, b.yhat AS y2
  FROM tabfm_regress('houses','price') a JOIN tabfm_regress('houses','price') b USING (sqft)
) WHERE y1 <> y2
----
0

# --- Two-table form ----------------------------------------------------------

statement ok
CREATE TABLE sold AS SELECT * FROM houses WHERE price IS NOT NULL;

statement ok
CREATE TABLE listed AS SELECT sqft, beds FROM houses WHERE price IS NULL;

query I
SELECT count(*) FROM tabfm_regress('sold','price', test := 'listed')
----
4

# --- Subselect training relation ---------------------------------------------

query I
SELECT count(*) FROM tabfm_regress('(SELECT * FROM sold)','price', test := 'listed')
----
4

# --- Errors ------------------------------------------------------------------

# all-NULL target: no context (raised before the model is touched)
statement ok
CREATE TABLE noprice AS SELECT sqft, NULL::DOUBLE AS price FROM houses;

statement error
SELECT * FROM tabfm_regress('noprice','price')
----
<REGEX>:.*no non-NULL rows.*

# n_estimators > 1 is a later milestone
statement error
SELECT * FROM tabfm_regress('houses','price', opts := MAP{'n_estimators':'4'})
----
<REGEX>:.*(ensemble|M3|n_estimators).*

# pointing regress at a CLASSIFICATION model errors on the task mismatch
statement ok
SET anofox_tabfm_model_manifest = 'test/fixtures/manifest.json'

statement error
SELECT * FROM tabfm_regress('houses','price')
----
<REGEX>:.*manifest is for task 'classification'.*

# no model configured -> not-downloaded remediation. Point the cache at an
# empty temp dir so a locally-downloaded real model does not mask this.
statement ok
SET anofox_tabfm_model_manifest = ''

statement ok
SET anofox_tabfm_cache_dir = '__TEST_DIR__/empty_cache'

statement error
SELECT * FROM tabfm_regress('houses','price')
----
<REGEX>:.*(not downloaded|tabfm_download).*
