# name: test/sql/tabfm_regress.test
# description: tabfm_regress surface + real-engine reachability. The committed CI
#              fixture is a CLASSIFICATION model, so a numeric regression forward
#              pass is exercised end-to-end in the real-weights / regression-
#              fixture job (Phase 3); here we assert the regression path reaches
#              the engine, resolves the task, and produces the SQL-API §5 errors.
# group: [anofox_tabfm]

require anofox_tabfm

statement ok
LOAD anofox_tabfm

statement ok
CREATE TABLE houses AS SELECT * FROM (VALUES
  (1200,3,200000.0),(2500,5,400000.0),(1500,3,NULL),(3000,6,NULL))
  v(sqft,beds,price);

# --- Regression task is resolved and reaches the engine ----------------------
# Pointed at the classification fixture, the engine rejects the task mismatch —
# proof the regression request flowed through preprocess/manifest resolution.

statement ok
SET anofox_tabfm_model_manifest = 'test/fixtures/manifest.json'

statement error
SELECT * FROM tabfm_regress('houses','price')
----
<REGEX>:.*manifest is for task 'classification'.*

# two-table form resolves the same way
statement ok
CREATE TABLE sold AS SELECT * FROM (VALUES (1200,3,200000.0),(2500,5,400000.0)) v(sqft,beds,price);

statement ok
CREATE TABLE listed AS SELECT * FROM (VALUES (1800,4),(2200,4)) v(sqft,beds);

statement error
SELECT * FROM tabfm_regress('sold','price', test := 'listed')
----
<REGEX>:.*manifest is for task 'classification'.*

# --- Errors that do not need a model -----------------------------------------

# all-NULL target: no context (raised before the model is touched)
statement ok
CREATE TABLE noprice AS SELECT sqft, NULL::DOUBLE AS price FROM houses;

statement error
SELECT * FROM tabfm_regress('noprice','price')
----
<REGEX>:.*no non-NULL rows.*

# n_estimators > 1 is a later milestone
statement error
SELECT * FROM tabfm_regress('houses','price', opts := MAP{'n_estimators':'4'})
----
<REGEX>:.*(ensemble|M3|n_estimators).*

# --- No model configured -> not-downloaded remediation -----------------------

statement ok
SET anofox_tabfm_model_manifest = ''

statement error
SELECT * FROM tabfm_regress('houses','price')
----
<REGEX>:.*(not downloaded|tabfm_download).*
