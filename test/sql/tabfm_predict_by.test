# name: test/sql/tabfm_predict_by.test
# description: tabfm_predict_by grouped macro — SQL-API §2 Level 3 (placeholder engine)
# group: [anofox_tabfm]

require anofox_tabfm

statement ok
LOAD anofox_tabfm

# Each group is a fully independent in-context model: its own context, its own
# label space. Placeholder engine: per-group majority / per-group mean.
# Output order is unspecified (hash-group-clustered, S04 #6) — always ORDER BY.

statement ok
CREATE TABLE demand(region VARCHAR, sku INTEGER, price DOUBLE, demand_class VARCHAR);

statement ok
INSERT INTO demand VALUES
    ('east', 1, 1.0, 'hi'),
    ('east', 2, 2.0, 'hi'),
    ('east', 3, 3.0, 'hi'),
    ('east', 4, 4.0, 'lo'),
    ('east', 5, 5.0, NULL),
    ('west', 1, 1.0, 'lo'),
    ('west', 2, 2.0, 'lo'),
    ('west', 3, 3.0, 'lo'),
    ('west', 4, 4.0, 'hi'),
    ('west', 5, 5.0, NULL);

# group column comes back among the input columns; per-group majority differs
query IIIII
SELECT region, sku, yhat, yhat_score, is_training
FROM tabfm_predict_by('demand', 'region', 'demand_class')
ORDER BY region, sku
----
east	1	hi	0.75	true
east	2	hi	0.75	true
east	3	hi	0.75	true
east	4	hi	0.75	true
east	5	hi	0.75	false
west	1	lo	0.75	true
west	2	lo	0.75	true
west	3	lo	0.75	true
west	4	lo	0.75	true
west	5	lo	0.75	false

# row count preserved
query I
SELECT count(*) FROM tabfm_predict_by('demand', 'region', 'demand_class')
----
10

# full name
query I
SELECT count(*) FROM anofox_tabfm_predict_by('demand', 'region', 'demand_class')
----
10

# --- feature-list variant keeps the group column in the projection (S04 note) --

query IIII
SELECT region, sku, demand_class, yhat
FROM tabfm_predict_by('demand', 'region', 'demand_class', ['sku'], MAP{})
ORDER BY region, sku LIMIT 2
----
east	1	hi	hi
east	2	hi	hi

# price was filtered out of the projection
statement error
SELECT price FROM tabfm_predict_by('demand', 'region', 'demand_class', ['sku'], MAP{})
----
price

# --- per-group independence, regression: one mean per group --------------------

# NOTE: avoid a column literally named 't' — the macro bodies alias the
# whole-row relation as 't' (S04), so a column 't' would shadow it.
statement ok
CREATE TABLE ts(grp VARCHAR, step INTEGER, y DOUBLE);

statement ok
INSERT INTO ts VALUES
    ('a', 1, 10.0), ('a', 2, 30.0), ('a', 3, NULL),
    ('b', 1, 100.0), ('b', 2, 300.0), ('b', 3, NULL);

query IIII
SELECT grp, step, yhat, is_training FROM tabfm_predict_by('ts', 'grp', 'y') ORDER BY grp, step
----
a	1	20.0	true
a	2	20.0	true
a	3	20.0	false
b	1	200.0	true
b	2	200.0	true
b	3	200.0	false

# opts flow through the grouped variant, detail mode included
query II
SELECT region, proba['hi']
FROM tabfm_predict_by('demand', 'region', 'demand_class', MAP{'output_mode': 'detail'})
WHERE sku = 1 ORDER BY region
----
east	0.75
west	0.25
