# name: test/sql/tabfm_predict.test
# description: tabfm_predict table macro — SQL-API §2 Levels 1-2 (placeholder engine)
# group: [anofox_tabfm]

require anofox_tabfm

statement ok
LOAD anofox_tabfm

# NOTE on expectations: WS-E ships a placeholder engine (real TabFM lands in
# Phase 2 behind the same seam): classification -> majority class of the
# non-NULL-target rows with yhat_score = majority fraction; regression -> mean
# with yhat_score NULL. Row order of the results is NOT guaranteed (S04 #6),
# so every query here orders explicitly.

statement ok
CREATE TABLE customers(age INTEGER, plan VARCHAR, usage_gb DOUBLE, churned VARCHAR);

statement ok
INSERT INTO customers VALUES
    (25, 'basic',  3.2, 'no'),
    (30, 'basic',  4.1, 'no'),
    (41, 'pro',   12.0, 'no'),
    (48, 'pro',   18.0, 'yes'),
    (33, 'basic',  5.0, NULL),
    (52, 'pro',   20.0, NULL);

# --- Level 1: simplest thing that works ---------------------------------------
# majority of {no,no,no,yes} = 'no' with fraction 0.75; NULL-target rows are
# scored (is_training = false), context rows get fitted values.

query IIIII
SELECT age, churned, yhat, yhat_score, is_training
FROM tabfm_predict('customers', 'churned') ORDER BY age
----
25	no	no	0.75	true
30	no	no	0.75	true
33	NULL	no	0.75	false
41	no	no	0.75	true
48	yes	no	0.75	true
52	NULL	no	0.75	false

# all input columns come back (join-back is trivial)
query IIII
SELECT age, plan, usage_gb, churned FROM tabfm_predict('customers', 'churned')
ORDER BY age LIMIT 2
----
25	basic	3.2	no
30	basic	4.1	no

# full name
query I
SELECT count(*) FROM anofox_tabfm_predict('customers', 'churned')
----
6

# target is resolved case-insensitively (S04 4b)
query I
SELECT count(*) FROM tabfm_predict('customers', 'Churned')
----
6

# --- regression: numeric target -> mean, yhat_score NULL ----------------------

statement ok
CREATE TABLE sales(id INTEGER, price DOUBLE, demand DOUBLE);

statement ok
INSERT INTO sales VALUES (1, 1.0, 10.0), (2, 2.0, 20.0), (3, 3.0, 30.0), (4, 4.0, NULL);

query IIII
SELECT id, yhat, yhat_score, is_training FROM tabfm_predict('sales', 'demand') ORDER BY id
----
1	20.0	NULL	true
2	20.0	NULL	true
3	20.0	NULL	true
4	20.0	NULL	false

# --- Level 2: feature list (case-insensitive) + opts --------------------------

# lcase() comparison on both sides: 'AGE'/'Plan' select age/plan (S04 2b);
# the target is always auto-included.
query III
SELECT age, churned, yhat FROM tabfm_predict('customers', 'churned', ['AGE', 'Plan'], MAP{})
ORDER BY age LIMIT 2
----
25	no	no
30	no	no

# usage_gb was filtered out of the projection
statement error
SELECT usage_gb FROM tabfm_predict('customers', 'churned', ['AGE', 'Plan'], MAP{})
----
usage_gb

# opts: n_estimators='1' and seed accepted
query I
SELECT count(*) FROM tabfm_predict('customers', 'churned', MAP{'n_estimators': '1', 'seed': '42'})
----
6

# output_mode='detail' adds proba MAP(label -> fraction)
query III
SELECT age, proba['no'], proba['yes']
FROM tabfm_predict('customers', 'churned', MAP{'output_mode': 'detail'})
ORDER BY age LIMIT 2
----
25	0.75	0.25
30	0.75	0.25

# task override: integer class codes forced to classification -> yhat keeps the
# target's type and is the majority code
statement ok
CREATE TABLE coded(x DOUBLE, klass INTEGER);

statement ok
INSERT INTO coded VALUES (1.0, 7), (2.0, 7), (3.0, 9), (4.0, NULL);

query II
SELECT x, yhat FROM tabfm_predict('coded', 'klass', MAP{'task': 'classification'}) ORDER BY x
----
1.0	7
2.0	7
3.0	7
4.0	7

# context_rows subsamples the context (first N context rows)
query I
SELECT DISTINCT yhat FROM tabfm_predict('sales', 'demand', MAP{'context_rows': '2'})
----
15.0

# --- duplicate-name rule: input yhat column keeps its name, prediction -> yhat_1

statement ok
CREATE TABLE has_yhat(id INTEGER, yhat VARCHAR, label VARCHAR);

statement ok
INSERT INTO has_yhat VALUES (1, 'keep_a', 'x'), (2, 'keep_b', 'x'), (3, 'keep_c', NULL);

query III
SELECT id, yhat, yhat_1 FROM tabfm_predict('has_yhat', 'label') ORDER BY id
----
1	keep_a	x
2	keep_b	x
3	keep_c	x

# --- nested STRUCT columns round-trip intact (unnest max_depth := 3, S04 4g) ---

statement ok
CREATE TABLE nested(id INTEGER, address STRUCT(street VARCHAR, city VARCHAR), label VARCHAR);

statement ok
INSERT INTO nested VALUES
    (1, {'street': 'Main 1', 'city': 'Berlin'}, 'a'),
    (2, {'street': 'Main 2', 'city': 'Hamburg'}, 'a'),
    (3, {'street': 'Main 3', 'city': 'Bremen'}, NULL);

query IIII
SELECT id, address.city, address.street, yhat FROM tabfm_predict('nested', 'label') ORDER BY id
----
1	Berlin	Main 1	a
2	Hamburg	Main 2	a
3	Bremen	Main 3	a

# the struct column itself is preserved (not flattened away)
query I
SELECT address FROM tabfm_predict('nested', 'label') WHERE id = 1
----
{'street': Main 1, 'city': Berlin}

# --- input flavors: VIEW, TEMP TABLE, schema-qualified (S04 4a/4c) -------------

statement ok
CREATE VIEW customer_view AS SELECT * FROM customers;

query I
SELECT count(*) FROM tabfm_predict('customer_view', 'churned')
----
6

statement ok
CREATE TEMP TABLE tmp_customers AS SELECT * FROM customers;

query I
SELECT count(*) FROM tabfm_predict('tmp_customers', 'churned')
----
6

query I
SELECT count(*) FROM tabfm_predict('main.customers', 'churned')
----
6

# --- no NULL targets: not an error — returns fitted rows only ------------------

statement ok
CREATE TABLE all_labeled(x INTEGER, y VARCHAR);

statement ok
INSERT INTO all_labeled VALUES (1, 'a'), (2, 'a'), (3, 'b');

query III
SELECT x, yhat, is_training FROM tabfm_predict('all_labeled', 'y') ORDER BY x
----
1	a	true
2	a	true
3	a	true
