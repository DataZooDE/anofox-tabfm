# name: test/sql/tabfm_classify.test
# description: tabfm_classify end-to-end through the real TabFM engine, driven by
#              the committed CI fixture model (weight-free graph + random-init
#              safetensors). Predictions are meaningless (random weights) but the
#              full pipeline runs: preprocess -> initializer injection -> ORT
#              forward -> softmax decode. We assert the plumbing and the
#              probabilistic contract, not specific labels (the fixture's classes
#              sit near 1/3 each, so the argmax is not platform-stable).
# group: [anofox_tabfm]

require anofox_tabfm

statement ok
LOAD anofox_tabfm

statement ok
SET anofox_tabfm_model_manifest = 'test/fixtures/manifest.json'

statement ok
CREATE TABLE t AS SELECT * FROM (VALUES
  (0.5,1.0,'a','x',0.1,'c0'),(1.5,0.2,'b','y',0.3,'c1'),(2.5,-1.0,'a','y',0.5,'c2'),
  (0.2,0.8,'b','x',0.7,'c0'),(1.1,0.4,'a','y',0.2,'c1'),(3.0,-0.5,'b','y',0.9,'c2'),
  (0.9,1.2,'a','x',0.6,'c0'),(2.1,0.1,'b','y',0.4,'c1'),
  (1.3,0.3,'a','y',0.35,NULL),(2.4,-0.2,'b','x',0.55,NULL),
  (0.7,0.9,'a','x',0.15,NULL),(1.8,-0.7,'b','y',0.75,NULL))
  v(f1,f2,f3,f4,f5,label);

# --- Single-table: 4 NULL-label rows are scored, all rows returned -----------

query I
SELECT count(*) FROM tabfm_classify('t','label')
----
12

# every predicted label is one of the training classes
query I
SELECT count(*) FROM tabfm_classify('t','label') WHERE yhat NOT IN ('c0','c1','c2')
----
0

# yhat is never NULL, the score is a probability
query I
SELECT count(*) FROM tabfm_classify('t','label') WHERE yhat IS NULL OR yhat_score <= 0 OR yhat_score > 1
----
0

# proba is a 3-entry distribution summing to 1
query I
SELECT count(*) FROM tabfm_classify('t','label') WHERE abs(list_sum(map_values(proba)) - 1.0) > 1e-5 OR len(map_keys(proba)) <> 3
----
0

# the scored (test) rows come back flagged is_training = false
query I
SELECT count(*) FROM tabfm_classify('t','label') WHERE label IS NULL AND is_training
----
0

# determinism: two identical calls agree on every prediction
query I
SELECT count(*) FROM (
  SELECT a.f1, a.yhat AS y1, b.yhat AS y2
  FROM tabfm_classify('t','label') a JOIN tabfm_classify('t','label') b USING (f1,f2)
) WHERE y1 <> y2
----
0

# --- Two-table form: fit on labelled rows, predict the unlabelled ones --------

statement ok
CREATE TABLE train AS SELECT * FROM t WHERE label IS NOT NULL;

statement ok
CREATE TABLE score AS SELECT f1,f2,f3,f4,f5 FROM t WHERE label IS NULL;

query I
SELECT count(*) FROM tabfm_classify('train','label', test := 'score')
----
4

# --- Subselect training relation ---------------------------------------------

query I
SELECT count(*) FROM tabfm_classify('(SELECT * FROM t WHERE label IS NOT NULL)','label', test := 'score')
----
4

# --- Target identifier is quoted in the generated SQL (spaces / keywords) -----
# The two-table form splices `NULL AS <target>`; a target needing quotes (a space
# here) must not break the query — the macro quotes it.
statement ok
CREATE TABLE train_q AS SELECT f1, f2, f3, f4, f5, label AS "class label" FROM t WHERE label IS NOT NULL;

query I
SELECT count(*) FROM tabfm_classify('train_q','class label', test := 'score')
----
4

# --- output_mode = compact drops proba ---------------------------------------

query I
SELECT count(*) FROM (DESCRIBE SELECT * FROM tabfm_classify('t','label', opts := MAP{'output_mode':'compact'})) WHERE column_name = 'proba'
----
0

# --- Errors ------------------------------------------------------------------

# more than 10 classes
statement ok
CREATE TABLE many AS SELECT (i*0.1) AS x, 'l' || (i % 14)::VARCHAR AS y FROM range(28) t(i);

statement error
SELECT * FROM tabfm_classify('many','y')
----
<REGEX>:.*at most 10.*

# all-NULL target: no context
statement ok
CREATE TABLE none AS SELECT (i*0.1) AS x, NULL::VARCHAR AS y FROM range(4) t(i);

statement error
SELECT * FROM tabfm_classify('none','y')
----
<REGEX>:.*no non-NULL rows.*

# n_estimators > 1 is a later milestone
statement error
SELECT * FROM tabfm_classify('t','label', opts := MAP{'n_estimators':'8'})
----
<REGEX>:.*(ensemble|M3|n_estimators).*

# unknown option key
statement error
SELECT * FROM tabfm_classify('t','label', opts := MAP{'nonsense':'1'})
----
<REGEX>:.*(unknown|invalid|option).*

# no model configured -> not-downloaded remediation (weights checked first).
# Point the cache at an empty temp dir so a locally-downloaded real model
# does not make this pass for the wrong reason.
statement ok
SET anofox_tabfm_model_manifest = ''

statement ok
SET anofox_tabfm_cache_dir = '__TEST_DIR__/empty_cache'

statement error
SELECT * FROM tabfm_classify('t','label')
----
<REGEX>:.*(not downloaded|tabfm_download).*
